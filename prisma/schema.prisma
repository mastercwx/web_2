// Prisma Schema 配置
// 文档: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

// 用户模型
model User {
  id               Int       @id @default(autoincrement())
  username         String    @unique @db.VarChar(50)
  email            String    @unique @db.VarChar(100)
  password         String    @db.VarChar(255)
  avatar           String?   @db.VarChar(255)
  role             Role      @default(USER)
  status           Status    @default(ACTIVE)
  resetToken       String?   @db.VarChar(64)
  resetTokenExpiry DateTime?
  emailVerified    Boolean   @default(false) @map("email_verified")
  verifyToken      String?   @unique @db.VarChar(64) @map("verify_token")
  verifyTokenExpiry DateTime? @map("verify_token_expiry")
  emailNotifications Boolean @default(true) @map("email_notifications")
  twoFactorEnabled   Boolean @default(false) @map("two_factor_enabled")
  twoFactorSecret    String? @db.VarChar(255) @map("two_factor_secret")
  twoFactorBackupCodes String? @db.Text @map("two_factor_backup_codes")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  // 关联
  posts     Post[]
  comments  Comment[]
  likes     Like[]
  favorites Favorite[]
  series    Series[]

  // 关注关系
  followers Follow[] @relation("following")
  following Follow[] @relation("follower")

  // 阅读历史
  readingHistory ReadingHistory[]

  // 通知
  notifications        Notification[] @relation("notifications_received")
  triggeredNotifications Notification[] @relation("notifications_actor")

  // 举报
  reports         Report[] @relation("reporter")
  resolvedReports Report[] @relation("resolved_reports")

  // 媒体文件
  mediaFiles Media[]

  // 活动日志
  activityLogs ActivityLog[]

  // 文章版本
  postVersions PostVersion[]

  // 表名映射
  @@map("users")
}

// 文章系列模型
model Series {
  id          Int      @id @default(autoincrement())
  title       String   @db.VarChar(200)
  description String?  @db.Text
  slug        String   @unique @db.VarChar(200)
  coverImage  String?  @db.VarChar(500) @map("cover_image")
  authorId    Int      @map("author_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // 关联
  author User @relation(fields: [authorId], references: [id])
  posts  Post[]

  // 索引
  @@index([authorId])
  @@map("series")
}

// 文章模型
model Post {
  id          Int       @id @default(autoincrement())
  title       String    @db.VarChar(200)
  content     String    @db.Text
  slug        String    @unique @db.VarChar(200)
  published   Boolean   @default(false)
  pinned      Boolean   @default(false)
  featured    Boolean   @default(false)
  scheduledAt DateTime? @map("scheduled_at")
  authorId    Int       @map("author_id")
  seriesId    Int?      @map("series_id")
  seriesOrder Int?      @map("series_order")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // 关联
  author    User       @relation(fields: [authorId], references: [id])
  series    Series?    @relation(fields: [seriesId], references: [id], onDelete: SetNull)
  tags      Tag[]
  comments  Comment[]
  likes     Like[]
  favorites Favorite[]
  versions  PostVersion[]

  // 阅读历史
  readingHistory ReadingHistory[]

  // 通知
  notifications Notification[]

  // 索引
  @@index([authorId])
  @@index([seriesId])
  @@index([scheduledAt])
  @@map("posts")
}

// 标签模型
model Tag {
  id    Int    @id @default(autoincrement())
  name  String @unique @db.VarChar(50)

  // 关联
  posts Post[]

  @@map("tags")
}

// 评论状态枚举
enum CommentStatus {
  PENDING
  APPROVED
  REJECTED
}

// 评论模型
model Comment {
  id        Int           @id @default(autoincrement())
  content   String        @db.Text
  status    CommentStatus @default(APPROVED)
  postId    Int           @map("post_id")
  authorId  Int           @map("author_id")
  parentId  Int?          @map("parent_id")
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  // 关联
  post   Post    @relation(fields: [postId], references: [id], onDelete: Cascade)
  author User    @relation(fields: [authorId], references: [id])
  parent Comment? @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies Comment[] @relation("CommentReplies")

  // 举报
  reports Report[]

  // 索引
  @@index([postId])
  @@index([authorId])
  @@index([status])
  @@index([parentId])
  @@map("comments")
}

// 举报模型
model Report {
  id          Int      @id @default(autoincrement())
  reason      String   @db.VarChar(500)
  description String?  @db.Text
  targetType  String   @map("target_type") @db.VarChar(20)
  targetId    Int      @map("target_id")
  reporterId  Int      @map("reporter_id")
  status      String   @default("pending") @db.VarChar(20)
  resolvedBy  Int?     @map("resolved_by")
  resolvedAt  DateTime? @map("resolved_at")
  createdAt   DateTime @default(now()) @map("created_at")

  // 关联
  reporter User  @relation("reporter", fields: [reporterId], references: [id])
  resolver User? @relation("resolved_reports", fields: [resolvedBy], references: [id])
  comment  Comment? @relation(fields: [targetId], references: [id], onDelete: Cascade)

  // 索引
  @@index([targetType])
  @@index([targetId])
  @@index([reporterId])
  @@index([status])
  @@map("reports")
}

// 点赞模型
model Like {
  id        Int      @id @default(autoincrement())
  postId    Int      @map("post_id")
  userId    Int      @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  // 关联
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  // 唯一约束
  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
  @@map("likes")
}

// 收藏模型
model Favorite {
  id        Int      @id @default(autoincrement())
  postId    Int      @map("post_id")
  userId    Int      @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  // 关联
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  // 唯一约束
  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
  @@map("favorites")
}

// 联系消息模型
model ContactMessage {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(100)
  email     String   @db.VarChar(200)
  subject   String?  @db.VarChar(200)
  content   String   @db.Text
  read      Boolean  @default(false)
  replied   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([read])
  @@index([createdAt])
  @@map("contact_messages")
}

// 系统设置模型
model Setting {
  id    Int    @id @default(autoincrement())
  key   String @unique @db.VarChar(100)
  value String @db.Text
  group String @default("general") @db.VarChar(50)
  label String? @db.VarChar(200)

  @@index([group])
  @@map("settings")
}

// 关注模型
model Follow {
  id          Int      @id @default(autoincrement())
  followerId  Int      @map("follower_id")
  followingId Int      @map("following_id")
  createdAt   DateTime @default(now()) @map("created_at")

  // 关联
  follower  User @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  // 唯一约束
  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@map("follows")
}

// 阅读历史模型
model ReadingHistory {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  postId    Int      @map("post_id")
  readAt    DateTime @default(now()) @map("read_at")

  // 关联
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  // 唯一约束（同一用户同一文章只记录一次，更新时间）
  @@unique([userId, postId])
  @@index([userId])
  @@index([postId])
  @@index([readAt])
  @@map("reading_history")
}

// 通知模型
model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  type      String   @db.VarChar(50)
  title     String   @db.VarChar(200)
  content   String?  @db.Text
  link      String?  @db.VarChar(500)
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  // 关联信息
  actorId   Int?     @map("actor_id")
  postId    Int?     @map("post_id")

  user  User  @relation("notifications_received", fields: [userId], references: [id], onDelete: Cascade)
  actor User? @relation("notifications_actor", fields: [actorId], references: [id], onDelete: SetNull)
  post  Post? @relation(fields: [postId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@index([type])
  @@map("notifications")
}

// 媒体文件模型
model Media {
  id         Int      @id @default(autoincrement())
  filename   String   @db.VarChar(255)
  originalName String @map("original_name") @db.VarChar(255)
  mimeType   String   @map("mime_type") @db.VarChar(100)
  size       Int
  url        String   @db.VarChar(500)
  alt        String?  @db.VarChar(255)
  caption    String?  @db.VarChar(500)
  folder     String   @default("uploads") @db.VarChar(100)
  uploaderId Int      @map("uploader_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // 关联
  uploader User @relation(fields: [uploaderId], references: [id])

  // 索引
  @@index([uploaderId])
  @@index([mimeType])
  @@index([folder])
  @@index([createdAt])
  @@map("media")
}

// 活动日志模型
model ActivityLog {
  id         Int      @id @default(autoincrement())
  userId     Int?     @map("user_id")
  action     String   @db.VarChar(50)
  entity     String?  @db.VarChar(50)
  entityId   Int?     @map("entity_id")
  details    String?  @db.Text
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  userAgent  String?  @map("user_agent") @db.VarChar(500)
  createdAt  DateTime @default(now()) @map("created_at")

  // 关联
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  // 索引
  @@index([userId])
  @@index([action])
  @@index([entity])
  @@index([createdAt])
  @@map("activity_logs")
}

// 文章版本历史模型
model PostVersion {
  id        Int      @id @default(autoincrement())
  postId    Int      @map("post_id")
  title     String   @db.VarChar(200)
  content   String   @db.Text
  version   Int
  comment   String?  @db.VarChar(500)
  authorId  Int      @map("author_id")
  createdAt DateTime @default(now()) @map("created_at")

  // 关联
  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id])

  // 索引
  @@unique([postId, version])
  @@index([postId])
  @@index([authorId])
  @@index([createdAt])
  @@map("post_versions")
}

// 用户角色枚举
enum Role {
  ADMIN
  USER
  GUEST
}

// 状态枚举
enum Status {
  ACTIVE
  INACTIVE
  BANNED
}
