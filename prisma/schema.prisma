// Prisma Schema 配置
// 文档: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

// 用户模型
model User {
  id               Int       @id @default(autoincrement())
  username         String    @unique @db.VarChar(50)
  email            String    @unique @db.VarChar(100)
  password         String    @db.VarChar(255)
  avatar           String?   @db.VarChar(255)
  role             Role      @default(USER)
  status           Status    @default(ACTIVE)
  resetToken       String?   @db.VarChar(64)
  resetTokenExpiry DateTime?
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  // 关联
  posts     Post[]
  comments  Comment[]
  likes     Like[]
  favorites Favorite[]

  // 关注关系
  followers Follow[] @relation("following")
  following Follow[] @relation("follower")

  // 阅读历史
  readingHistory ReadingHistory[]

  // 通知
  notifications        Notification[] @relation("notifications_received")
  triggeredNotifications Notification[] @relation("notifications_actor")

  // 表名映射
  @@map("users")
}

// 文章模型
model Post {
  id          Int       @id @default(autoincrement())
  title       String    @db.VarChar(200)
  content     String    @db.Text
  slug        String    @unique @db.VarChar(200)
  published   Boolean   @default(false)
  scheduledAt DateTime? @map("scheduled_at")
  authorId    Int       @map("author_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // 关联
  author    User       @relation(fields: [authorId], references: [id])
  tags      Tag[]
  comments  Comment[]
  likes     Like[]
  favorites Favorite[]

  // 阅读历史
  readingHistory ReadingHistory[]

  // 通知
  notifications Notification[]

  // 索引
  @@index([authorId])
  @@index([scheduledAt])
  @@map("posts")
}

// 标签模型
model Tag {
  id    Int    @id @default(autoincrement())
  name  String @unique @db.VarChar(50)

  // 关联
  posts Post[]

  @@map("tags")
}

// 评论模型
model Comment {
  id        Int      @id @default(autoincrement())
  content   String   @db.Text
  postId    Int      @map("post_id")
  authorId  Int      @map("author_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // 关联
  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id])

  // 索引
  @@index([postId])
  @@index([authorId])
  @@map("comments")
}

// 点赞模型
model Like {
  id        Int      @id @default(autoincrement())
  postId    Int      @map("post_id")
  userId    Int      @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  // 关联
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  // 唯一约束
  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
  @@map("likes")
}

// 收藏模型
model Favorite {
  id        Int      @id @default(autoincrement())
  postId    Int      @map("post_id")
  userId    Int      @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  // 关联
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  // 唯一约束
  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
  @@map("favorites")
}

// 联系消息模型
model ContactMessage {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(100)
  email     String   @db.VarChar(200)
  subject   String?  @db.VarChar(200)
  content   String   @db.Text
  read      Boolean  @default(false)
  replied   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([read])
  @@index([createdAt])
  @@map("contact_messages")
}

// 系统设置模型
model Setting {
  id    Int    @id @default(autoincrement())
  key   String @unique @db.VarChar(100)
  value String @db.Text
  group String @default("general") @db.VarChar(50)
  label String? @db.VarChar(200)

  @@index([group])
  @@map("settings")
}

// 关注模型
model Follow {
  id          Int      @id @default(autoincrement())
  followerId  Int      @map("follower_id")
  followingId Int      @map("following_id")
  createdAt   DateTime @default(now()) @map("created_at")

  // 关联
  follower  User @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  // 唯一约束
  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@map("follows")
}

// 阅读历史模型
model ReadingHistory {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  postId    Int      @map("post_id")
  readAt    DateTime @default(now()) @map("read_at")

  // 关联
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  // 唯一约束（同一用户同一文章只记录一次，更新时间）
  @@unique([userId, postId])
  @@index([userId])
  @@index([postId])
  @@index([readAt])
  @@map("reading_history")
}

// 通知模型
model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  type      String   @db.VarChar(50)
  title     String   @db.VarChar(200)
  content   String?  @db.Text
  link      String?  @db.VarChar(500)
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  // 关联信息
  actorId   Int?     @map("actor_id")
  postId    Int?     @map("post_id")

  user  User  @relation("notifications_received", fields: [userId], references: [id], onDelete: Cascade)
  actor User? @relation("notifications_actor", fields: [actorId], references: [id], onDelete: SetNull)
  post  Post? @relation(fields: [postId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@index([type])
  @@map("notifications")
}

// 用户角色枚举
enum Role {
  ADMIN
  USER
  GUEST
}

// 状态枚举
enum Status {
  ACTIVE
  INACTIVE
  BANNED
}
